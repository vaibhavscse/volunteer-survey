# Twilio credentials — get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio Verify Service SID — create one at Console > Verify > Services
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# Path to SQLite database file.
# On Railway set this to /data/volunteers.db and mount a volume at /data.
# Leave unset for local development (defaults to ./volunteers.db).
# DATABASE_PATH=/data/volunteers.db
